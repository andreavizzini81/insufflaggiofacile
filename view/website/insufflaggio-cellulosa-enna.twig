{% set faq_3 = 'Sì, conviene quando vuoi ridurre dispersioni, migliorare la stabilità termica e rendere la casa più confortevole durante tutto l’anno.' %}
{% set faq_4 = 'In media l’intervento può durare da poche ore a due giorni, in base alla dimensione dell’immobile e alla complessità delle pareti da trattare.' %}
{% set faq_5 = 'No, non servono demolizioni importanti: l’insufflaggio viene eseguito tramite piccoli fori tecnici che vengono poi ripristinati.' %}
{% set faq_6 = 'Sì, a Enna l’insufflaggio di cellulosa è utile per limitare sbalzi termici, migliorare il comfort interno e aumentare l’efficienza dell’abitazione.' %}


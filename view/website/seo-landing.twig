{% extends "index.twig" %}{% block content %}<section class="page_title ds s-pt-115 s-pb-65 s-pb-lg-85 s-pt-lg-145 s-parallax s-overlay"><div class="container"><h1 class="color-main">{{ data.landing.h1 }}</h1><p>{{ data.landing.introText }}</p><a href="{{ data.landing.heroCtaUrl }}" class="btn btn-maincolor">{{ data.landing.heroCtaLabel }}</a></div></section><section class="ls s-py-60"><div class="container">{{ data.landing.mainContent|raw }}</div></section>{% for section in data.sections %}<section class="ls s-py-50"><div class="container"><h2>{{ section.title }}</h2><div>{{ section.content|raw }}</div></div></section>{% endfor %}<section class="ds s-py-60"><div class="container"><h2>Province servite in Sicilia</h2><p><a href="/insufflaggio-cellulosa-catania">Catania</a>, <a href="/insufflaggio-cellulosa-palermo">Palermo</a>, <a href="/insufflaggio-cellulosa-messina">Messina</a>, <a href="/insufflaggio-cellulosa-siracusa">Siracusa</a>, <a href="/insufflaggio-cellulosa-ragusa">Ragusa</a>, <a href="/insufflaggio-cellulosa-trapani">Trapani</a>, <a href="/insufflaggio-cellulosa-agrigento">Agrigento</a>, <a href="/insufflaggio-cellulosa-enna">Enna</a>, <a href="/insufflaggio-cellulosa-caltanissetta">Caltanissetta</a></p></div></section>{% if data.relatedSeoLandingPages|length > 0 %}<section class="ls s-py-60"><div class="container"><h2>Approfondimenti correlati</h2><p>Altri contenuti utili sullo stesso argomento:</p><ul>{% for relatedPage in data.relatedSeoLandingPages %}<li><a href="/{{ relatedPage.slug }}">{{ relatedPage.menu_label ?: (relatedPage.h1 ?: relatedPage.title) }}</a>{% if relatedPage.meta_description %} - {{ relatedPage.meta_description }}{% endif %}</li>{% endfor %}</ul></div></section>{% endif %}<section class="ls s-py-60"><div class="container"><h2>Domende frequenti</h2><div class="accordion" id="accordion-seo-landing" role="tablist">{% for faq in data.faqItems %}<div class="card"><div class="card-header" role="tab" id="faq_{{ loop.index }}_header"><h6><a class="collapsed" href="#faq_{{ loop.index }}" data-toggle="collapse" aria-expanded="false" aria-controls="faq_{{ loop.index }}">{{ faq.q }}</a></h6></div><div class="collapse" id="faq_{{ loop.index }}" role="tabpanel" aria-labelledby="faq_{{ loop.index }}_header" data-parent="#accordion-seo-landing"><div class="card-body"><p>{{ faq.a }}</p></div></div></div>{% endfor %}</div><a href="/richiedi-preventivo" class="btn btn-maincolor mt-40">Richiedi un preventivo gratuito</a></div></section>{% endblock %} 